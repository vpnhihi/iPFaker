	     iPFaker — main configuration
	     Target: Zalo (com.zing.zalo)
	     ═══════════════════════════════════════════ -->

	<!-- ─── Meta ─── -->
	<key>Enabled</key>
	<true/>
	<key>Version</key>
	<string>2.1.1</string>
	<key>ConfigName</key>
	<string>main</string>
	<key>Description</key>
	<string>Full device spoof for Zalo — ONE BUTTON applies Fake Nông + Fake Sâu</string>

	<!-- ═══ ONE-BUTTON FULL APPLY (Nông + Sâu) ═══ -->
	<key>FakeLevel</key>
	<string>full</string>
	<key>OneButtonFullFake</key>
	<true/>
	<key>ApplyNong</key>
	<true/>
	<key>ApplySau</key>
	<true/>
	<key>RequireBothLevels</key>
	<true/>
	<key>AbortIfPartial</key>
	<true/>
	<key>MergeStrategy</key>
	<string>nong_first_sau_override</string>
	<key>ButtonAction</key>
	<string>apply_full_nong_and_sau</string>
	<key>OnLoadApplyFull</key>
	<true/>
	<key>ModulesAll</key>
	<true/>

	<key>DeviceProfileFile</key>
	<string>config/device_profile.json</string>
	<key>ActiveProfileFile</key>
	<string>config/active_profile.json</string>
	<key>ApplyConfigFile</key>
	<string>config/apply.json</string>
	<key>InjectorApplyPlist</key>
	<string>injector/ApplyFull.plist</string>

	<!-- ─── Target filter ─── -->
	<key>Target</key>
	<dict>
		<key>BundleID</key>
		<string>com.zing.zalo</string>
		<key>BundleIDs</key>
		<array>
			<string>com.zing.zalo</string>
		</array>
		<key>MatchMode</key>
		<string>exact</string>
		<!-- only inject / apply hooks for listed bundle IDs -->
		<key>ScopeToTargetOnly</key>
		<true/>
		<!-- also match Zalo share / notification extensions if present -->
		<key>IncludeAppExtensions</key>
		<false/>
	</dict>

	<!-- ─── Module master switches ───
	     true  = hook active for target
	     false = module skipped
	     ─── -->
	<key>Modules</key>
	<dict>
		<!-- MGCopyAnswer / libMobileGestalt -->
		<key>MobileGestalt</key>
		<true/>

		<!-- sysctl / sysctlbyname (hw.*, kern.*) -->
		<key>Sysctl</key>
		<true/>

		<!-- UIDevice: name, model, systemVersion, identifierForVendor, ... -->
		<key>UIDevice</key>
		<true/>

		<!-- ASIdentifierManager advertisingIdentifier (IDFA) -->
		<key>IDFA</key>
		<true/>

		<!-- CTCarrier / CTTelephonyNetworkInfo -->
		<key>CoreTelephony</key>
		<true/>

		<!-- Wipe / reseed keychain items used as device binding -->
		<key>KeychainWipe</key>
		<true/>

		<!-- IOKit registry / IOPlatformSerialNumber, etc. -->
		<key>IOKit</key>
		<true/>

		<!-- uname() machine / nodename -->
		<key>Uname</key>
		<true/>

		<!-- NSProcessInfo / operatingSystemVersionString -->
		<key>NSProcessInfo</key>
		<true/>

		<!-- NSLocale / preferred languages / region if fingerprinted -->
		<key>NSLocale</key>
		<true/>

		<!-- dyld image path / boot-args style probes (Fake Sâu) -->
		<key>Dyld</key>
		<true/>

		<!-- File-path existence checks for jailbreak (Fake Sâu) -->
		<key>JailbreakHide</key>
		<true/>

		<!-- CANNetwork / MAC-related if exposed in-process -->
		<key>NetworkInterface</key>
		<true/>

		<!-- UIScreen bounds / scale consistency with spoofed model -->
		<key>UIScreen</key>
		<true/>

		<!-- Disk capacity / free space snapshot spoof -->
		<key>DiskSpace</key>
		<true/>

		<!-- IDFV dedicated path (also covered partly by UIDevice) -->
		<key>IDFV</key>
		<true/>

		<!-- ── Fake Sâu modules ── -->
		<key>SecureElement</key>
		<true/>
		<key>ESIM</key>
		<true/>
		<key>TelephonyDeep</key>
		<true/>
		<key>MGCapabilities</key>
		<true/>
		<key>SysctlDeep</key>
		<true/>
		<key>MetalGPU</key>
		<true/>
		<key>CameraSensors</key>
		<true/>
		<key>Biometry</key>
		<true/>
		<key>DisplayDeep</key>
		<true/>
		<key>BootTime</key>
		<true/>
		<key>VolumeUUID</key>
		<true/>
		<key>WebViewUA</key>
		<true/>
		<key>SDKAttribution</key>
		<true/>
		<key>ZaloStorageWipe</key>
		<true/>
		<key>IdentityDeep</key>
		<true/>
	</dict>

