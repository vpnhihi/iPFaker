#!/bin/sh
# iPFaker postinst — rootless Dopamine / RootHide wall (MG+CT+JB)
set -e

ROOT="${JBROOT:-/var/jb}"

# Prefer TweakInject (ElleKit); DynamicLibraries may symlink there
for d in \
  "$ROOT/usr/lib/TweakInject" \
  "/var/jb/usr/lib/TweakInject" \
  "$ROOT/Library/MobileSubstrate/DynamicLibraries" \
  "/var/jb/Library/MobileSubstrate/DynamicLibraries" \
  "/Library/MobileSubstrate/DynamicLibraries"
do
  [ -d "$d" ] || continue
  for f in iPFakerMG.dylib iPFakerCT.dylib iPFakerJB.dylib \
           iPFakerAbout.dylib iPFakerAboutUI.dylib iPFakerAboutVer.dylib iPFakerAA.dylib \
           iPFakerMG.plist iPFakerCT.plist iPFakerJB.plist \
           iPFakerAbout.plist iPFakerAboutUI.plist iPFakerAboutVer.plist iPFakerAA.plist; do
    p="$d/$f"
    [ -e "$p" ] || continue
    chown root:wheel "$p" 2>/dev/null || true
    case "$f" in
      *.dylib) chmod 0755 "$p" 2>/dev/null || true ;;
      # Filter plists: mobile-writable so Fake can update inject list without root
      # (Telegram/FB/… must be written live — package default is Zalo-only)
      *.plist) chmod 0666 "$p" 2>/dev/null || true ;;
      *)       chmod 0644 "$p" 2>/dev/null || true ;;
    esac
    # trustcache when available
    if [ -x /var/jb/basebin/jbctl ] && command -v ldid >/dev/null 2>&1 && [ "${f##*.}" = "dylib" ]; then
      H=$(ldid -h "$p" 2>/dev/null | sed -n 's/.*CDHash=//p' | head -1 | tr 'A-F' 'a-f' | cut -c1-40)
      if [ ${#H} -eq 40 ]; then
        /var/jb/basebin/jbctl trustcache add "$H" 2>/dev/null || true
      fi
    fi
  done
done

# Wipe helpers (multi-app Zalo-depth)
for w in \
  /var/jb/usr/libexec/ipfaker-wipe-apps /var/jb/etc/ipfaker/wipe_apps.sh /var/mobile/Library/iPFaker/wipe_apps.sh \
  /var/jb/usr/libexec/ipfaker-wipe-zalo /var/jb/etc/ipfaker/wipe_zalo.sh /var/mobile/Library/iPFaker/wipe_zalo.sh \
  /var/jb/usr/libexec/ipfaker-wipe-zalo-session /var/jb/etc/ipfaker/wipe_zalo_session.sh /var/mobile/Library/iPFaker/wipe_zalo_session.sh
do
  if [ -f "$w" ]; then
    chmod 755 "$w" 2>/dev/null || true
    chown root:wheel "$w" 2>/dev/null || true
  fi
done

# Config dirs: mobile-writable so app Apply can write without root
for ETC in \
  "$ROOT/etc/ipfaker" \
  "/var/jb/etc/ipfaker" \
  "/etc/ipfaker"
do
  mkdir -p "$ETC" 2>/dev/null || true
  if [ -d "$ETC" ]; then
    chown -R mobile:mobile "$ETC" 2>/dev/null || true
    chmod 0775 "$ETC" 2>/dev/null || true
    if [ ! -f "$ETC/README.txt" ]; then
      cat > "$ETC/README.txt" <<'EOF'
iPFaker config directory (lab wall)
- config.plist + active_profile.json written by iPFaker.app or PC select_device_profile.py
- Dylibs: iPFakerMG (spoof) + iPFakerCT (telephony) + iPFakerJB (hide expand)
- Mirror: /var/mobile/Library/iPFaker/
EOF
    fi
  fi
done

MOB="/var/mobile/Library/iPFaker"
mkdir -p "$MOB" 2>/dev/null || true
chown mobile:mobile "$MOB" 2>/dev/null || true
chmod 0755 "$MOB" 2>/dev/null || true

killall -9 Zalo 2>/dev/null || true
exit 0
