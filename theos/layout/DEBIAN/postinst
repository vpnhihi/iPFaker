#!/bin/sh
# iPFaker postinst — reboot ONLY after dpkg fully finishes (no mid-install reboot).
ROOT="${JBROOT:-/var/jb}"
export PATH="/var/jb/usr/bin:/var/jb/usr/sbin:/var/jb/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

for d in \
  "$ROOT/usr/lib/TweakInject" \
  "/var/jb/usr/lib/TweakInject" \
  "$ROOT/Library/MobileSubstrate/DynamicLibraries" \
  "/var/jb/Library/MobileSubstrate/DynamicLibraries"
do
  [ -d "$d" ] || continue
  for f in iPFakerMG.dylib iPFakerCT.dylib iPFakerJB.dylib \
           iPFakerAbout.dylib iPFakerAboutUI.dylib iPFakerAboutVer.dylib iPFakerAA.dylib \
           iPFakerMG.plist iPFakerCT.plist iPFakerJB.plist \
           iPFakerAbout.plist iPFakerAboutUI.plist iPFakerAboutVer.plist iPFakerAA.plist; do
    p="$d/$f"
    [ -e "$p" ] || continue
    chown root:wheel "$p" 2>/dev/null || true
    case "$f" in
      *.dylib) chmod 0755 "$p" 2>/dev/null || true ;;
      *.plist) chmod 0666 "$p" 2>/dev/null || true ;;
    esac
  done
done

mkdir -p /var/jb/etc/ipfaker /var/mobile/Library/iPFaker/logs /var/jb/Library/LaunchDaemons 2>/dev/null || true
chown mobile:mobile /var/mobile/Library/iPFaker 2>/dev/null || true

killall -9 Zalo 2>/dev/null || true
killall -9 Preferences 2>/dev/null || true

if [ -z "$IPFAKER_SKIP_USERSPACE_REBOOT" ]; then
  # Full waiter is written by Sileo package postinst; minimal schedule here for Theos path
  if [ -x /var/jb/etc/ipfaker/userspace_reboot_once.sh ]; then
    touch /var/jb/etc/ipfaker/.pending_userspace_reboot 2>/dev/null || true
    nohup /bin/sh /var/jb/etc/ipfaker/userspace_reboot_once.sh >/dev/null 2>&1 &
  fi
fi

exit 0
